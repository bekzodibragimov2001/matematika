# Vercel Postgres ma'lumotlar bazasi ulanishi
# Vercel loyihasiga "Postgres" storage qo'shsangiz, bu qiymatlar avtomatik qo'shiladi.
POSTGRES_URL=

# Admin kirish ma'lumotlari (talab bo'yicha "adminloginpassword" faylida ham saqlanadi)
ADMIN_USERNAME=mathadmin
ADMIN_PASSWORD=mathadminpassword

# JWT tokenlarni imzolash uchun maxfiy kalit - production uchun tasodifiy uzun matn qo'ying
JWT_SECRET=please-change-this-to-a-long-random-string
